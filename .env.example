# ── Database ──────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/portfolio_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Server ────────────────────────────────────────────────────────
PORT=8080

# ── CORS — comma-separated allowed origins ────────────────────────
CORS_ORIGINS=http://localhost:3000,https://ibrahim.dev

# ── Contact Email ─────────────────────────────────────────────────
CONTACT_EMAIL=ibrahim@email.com

# ── Mail (Gmail SMTP) ─────────────────────────────────────────────
# Use an App Password — NOT your real Gmail password
# Go to: Google Account > Security > 2FA > App Passwords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-16-char-app-password
